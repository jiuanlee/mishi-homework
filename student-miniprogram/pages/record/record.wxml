<view class="record-container">
  <view class="header">
    <text class="title">📖 我的学习记录</text>
  </view>

  <view class="stats-section">
    <view class="stat-card">
      <view class="stat-icon">📝</view>
      <view class="stat-info">
        <text class="stat-value">{{stats.completedCount}}</text>
        <text class="stat-label">完成作业</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon">⭐</view>
      <view class="stat-info">
        <text class="stat-value">{{stats.totalScore}}</text>
        <text class="stat-label">总得分</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon">🏅</view>
      <view class="stat-info">
        <text class="stat-value">{{stats.badgesCount}}</text>
        <text class="stat-label">徽章数</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon">🪙</view>
      <view class="stat-info">
        <text class="stat-value">{{stats.coinsCount}}</text>
        <text class="stat-label">金币数</text>
      </view>
    </view>
  </view>

  <view class="section-title">
    <text class="title-icon">📚</text>
    <text class="title-text">作业记录</text>
  </view>

  <view class="record-list">
    <view 
      class="record-item" 
      wx:for="{{recordList}}" 
      wx:key="id"
    >
      <view class="record-header">
        <text class="record-name">{{item.name}}</text>
        <text class="record-date">{{item.date}}</text>
      </view>
      <view class="record-detail">
        <view class="detail-row">
          <text class="detail-label">模式：</text>
          <text class="detail-value">{{item.mode}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">得分：</text>
          <text class="detail-value score">{{item.score}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">用时：</text>
          <text class="detail-value">{{item.duration}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">奖励：</text>
          <text class="detail-value rewards">🪙{{item.coins}} 🏅{{item.badges}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{recordList.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">还没有作业记录哦~</text>
  </view>
</view>
