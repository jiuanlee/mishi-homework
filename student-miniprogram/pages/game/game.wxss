.game-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  position: relative;
  overflow: hidden;
}

/* 剧情展示 */
.story-section {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.story-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
}

.story-content {
  position: relative;
  z-index: 10;
  background: white;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 85%;
  text-align: center;
}

.story-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.story-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 40rpx;
  min-height: 200rpx;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  padding: 25rpx 80rpx;
}

/* 游戏主界面 */
.game-section {
  padding: 30rpx;
}

.game-header {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.info-value {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.clue-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.clue-title {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.clue-list {
  white-space: nowrap;
}

.clue-item {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  margin-right: 15rpx;
}

.clue-item.unlocked {
  background: rgba(102, 126, 234, 0.5);
}

.clue-item.locked {
  opacity: 0.5;
}

.clue-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.clue-name {
  color: white;
  font-size: 24rpx;
}

.question-section {
  margin-top: 20rpx;
}

.question-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
}

.question-type {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-tag {
  background: #667eea;
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.question-number {
  color: #999;
  font-size: 24rpx;
}

.question-content {
  margin-bottom: 30rpx;
}

.question-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.question-image {
  width: 100%;
  border-radius: 15rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 15rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item:active {
  background: #e8e8e8;
}

.option-item.selected {
  background: #ecf5ff;
  border-color: #667eea;
}

.option-label {
  background: #667eea;
  color: white;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: white;
  color: #667eea;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  padding: 25rpx;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

/* 解锁动画 */
.unlock-animation {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.3s;
}

.unlock-content {
  text-align: center;
  animation: bounceIn 0.5s;
}

.unlock-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.unlock-text {
  display: block;
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.unlock-clue {
  display: block;
  font-size: 32rpx;
  color: #ffd700;
}

/* 通关结算 */
.result-section {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.8);
}

.result-card {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 85%;
  text-align: center;
}

.result-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 36rpx;
  color: #667eea;
  font-weight: bold;
}

.rewards {
  margin-bottom: 40rpx;
}

.rewards-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.rewards-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.reward-item {
  font-size: 28rpx;
  color: #333;
}

.back-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  padding: 25rpx 80rpx;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes bounceIn {
  0% { transform: scale(0); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}
