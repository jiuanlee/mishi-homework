.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-section {
  width: 100%;
  background: white;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  display: block;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.input-box {
  width: 100%;
  height: 90rpx;
  background: #f5f7fa;
  border-radius: 15rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-box:focus {
  background: white;
  border-color: #667eea;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
  margin-top: 20rpx;
}

.login-btn[loading] {
  opacity: 0.8;
}

.tips {
  margin-top: 40rpx;
  padding: 25rpx;
  background: #fff7e6;
  border-radius: 15rpx;
}

.tips-text {
  color: #ff9900;
  font-size: 24rpx;
  line-height: 1.6;
}
